# Leave DATABASE_URL blank if you deploy the database with:
# powershell -ExecutionPolicy Bypass -File .\scripts\aws\deploy.ps1 -DeployDatabase
# The deploy script will inject the generated RDS connection string into App Runner.
DATABASE_URL=
JWT_SECRET=replace-with-a-random-secret-of-at-least-32-characters
JWT_ISSUER=fieldfriends
JWT_AUDIENCE=fieldfriends-users
JWT_EXPIRES_MINUTES=60
CORS_ORIGINS=https://your-frontend-domain
