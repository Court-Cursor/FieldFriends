# Copy this file to scripts/aws/deploy.env and fill in the values before deploying.

AWS_REGION=ap-southeast-1
AWS_PROFILE=
ECR_REPOSITORY=fieldfriends-backend
BACKEND_IMAGE_TAG=latest
APP_RUNNER_SERVICE=fieldfriends-backend
APP_RUNNER_ACCESS_ROLE_ARN=arn:aws:iam::123456789012:role/AppRunnerEcrAccessRole
APP_RUNNER_CPU=1024
APP_RUNNER_MEMORY=2048
BACKEND_ENV_FILE=backend/.env.aws
VPC_ID=
VPC_SUBNET_IDS=
APP_RUNNER_VPC_CONNECTOR=fieldfriends-apprunner-vpc
APP_RUNNER_VPC_SECURITY_GROUP=fieldfriends-apprunner-sg
DB_INSTANCE_IDENTIFIER=fieldfriends-db
DB_SUBNET_GROUP=fieldfriends-db-subnets
DB_SECURITY_GROUP=fieldfriends-db-sg
DB_NAME=fieldfriends
DB_USERNAME=fieldfriends
DB_MASTER_PASSWORD=
DB_INSTANCE_CLASS=db.t3.micro
DB_ALLOCATED_STORAGE=20
DB_ENGINE_VERSION=16.3
DB_PUBLIC_ACCESS=false
DB_ALLOWED_CIDRS=
FRONTEND_BUCKET=your-unique-fieldfriends-site-bucket
FRONTEND_API_URL=
CLOUDFRONT_DISTRIBUTION_ID=
